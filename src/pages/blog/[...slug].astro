---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | Agent Debugger`}>
  <article class="max-w-3xl mx-auto px-4 pt-24 pb-16">
    <div class="mb-8">
      <div class="flex items-center gap-3 text-xs text-zinc-500 mb-4">
        <a href="/blog" class="text-indigo-400 hover:text-indigo-300">← Back to Blog</a>
        <span>·</span>
        <span>{post.data.category}</span>
        <span>·</span>
        <span>{post.data.readTime} min read</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>
      <p class="text-lg text-zinc-400">{post.data.description}</p>
      <div class="text-sm text-zinc-600 mt-3">
        {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </div>
    </div>

    <div class="prose prose-invert max-w-none">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .prose h1 { font-size: 2rem; font-weight: 700; margin-top: 2rem; margin-bottom: 1rem; }
  .prose h2 { font-size: 1.5rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: #e4e4e7; }
  .prose h3 { font-size: 1.25rem; font-weight: 600; margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .prose p { color: #a1a1aa; line-height: 1.7; margin-bottom: 1rem; }
  .prose strong { color: #e4e4e7; }
  .prose ul { color: #a1a1aa; margin-bottom: 1rem; padding-left: 1.5rem; list-style-type: disc; }
  .prose ol { color: #a1a1aa; margin-bottom: 1rem; padding-left: 1.5rem; list-style-type: decimal; }
  .prose li { margin-bottom: 0.25rem; }
  .prose code { background: #18181b; padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875rem; border: 1px solid #27272a; }
  .prose pre { background: #09090b; border: 1px solid #27272a; border-radius: 0.5rem; padding: 1rem; overflow-x: auto; margin-bottom: 1rem; }
  .prose pre code { background: none; border: none; padding: 0; }
  .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
  .prose th, .prose td { border: 1px solid #27272a; padding: 0.5rem 0.75rem; text-align: left; font-size: 0.875rem; }
  .prose th { background: #18181b; color: #e4e4e7; font-weight: 600; }
  .prose td { color: #a1a1aa; }
  .prose a { color: #818cf8; text-decoration: underline; }
  .prose a:hover { color: #a5b4fc; }
  .prose blockquote { border-left: 3px solid #6366f1; padding-left: 1rem; color: #a1a1aa; font-style: italic; }
</style>
