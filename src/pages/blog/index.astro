---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Agent Debugging Blog | AI Agent Monitoring Tips">
  <section class="max-w-4xl mx-auto px-4 pt-24 pb-16">
    <h1 class="text-4xl font-bold mb-4">Blog</h1>
    <p class="text-zinc-400 mb-12 max-w-lg">Tips, guides, and deep dives into AI agent debugging, monitoring, and multi-agent systems.</p>

    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="glow-card p-6 block hover:border-indigo-500/30 transition-all">
          <div class="text-xs text-indigo-400 mb-2">{post.data.category}</div>
          <h2 class="text-xl font-bold mb-2">{post.data.title}</h2>
          <p class="text-sm text-zinc-500 mb-3">{post.data.description}</p>
          <div class="flex items-center gap-3 text-xs text-zinc-600">
            <span>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            <span>·</span>
            <span>{post.data.readTime} min read</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
