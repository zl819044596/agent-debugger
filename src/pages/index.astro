---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Best AI Agent Debugging Tool | Multi-Agent Monitoring Platform">
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-indigo-900/20 via-transparent to-transparent pointer-events-none"></div>
    <div class="max-w-6xl mx-auto px-4 pt-24 pb-16 text-center relative">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-indigo-500/30 bg-indigo-500/10 text-indigo-300 text-xs mb-6">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        Live in beta — free during early access
      </div>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6">
        Debug Your AI Agents<br />
        <span class="gradient-text">Like Chrome DevTools</span>
      </h1>
      <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-10">
        The <strong class="text-zinc-200">agent debugging tool</strong> that traces every step — 
        thinking, tool calls, decisions, and outputs. Debug single agents or visualize 
        <strong class="text-zinc-200">multi-agent collaboration</strong> across any framework.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="#cta" class="btn-primary text-lg px-8 py-4">Start Debugging Free →</a>
        <a href="#demo" class="btn-secondary text-lg px-8 py-4">Watch Demo</a>
      </div>
      <p class="text-sm text-zinc-600 mt-4">No credit card · 30-day retention · AutoGen, CrewAI, LangGraph</p>
    </div>
  </section>

  <!-- Social Proof / Logos -->
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <p class="text-xs text-zinc-600 uppercase tracking-widest mb-8">Built for teams building with</p>
    <div class="flex flex-wrap justify-center gap-8 text-zinc-500 text-lg font-mono">
      <span class="hover:text-zinc-300 transition-colors">LangChain</span>
      <span class="hover:text-zinc-300 transition-colors">AutoGen</span>
      <span class="hover:text-zinc-300 transition-colors">CrewAI</span>
      <span class="hover:text-zinc-300 transition-colors">LangGraph</span>
      <span class="hover:text-zinc-300 transition-colors">Custom Agents</span>
    </div>
  </section>

  <!-- Problem -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Your Agents Are Black Boxes
      </h2>
      <p class="text-zinc-400 max-w-xl mx-auto">
        AI agents make decisions, call tools, and consume tokens — but you have no idea what's happening inside.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="glow-card p-6">
        <div class="text-3xl mb-3">🔍</div>
        <h3 class="font-semibold mb-2">Where's the bug?</h3>
        <p class="text-sm text-zinc-500">Your agent returned wrong results but you can't trace which step failed. Hours of log spelunking.</p>
      </div>
      <div class="glow-card p-6">
        <div class="text-3xl mb-3">💰</div>
        <h3 class="font-semibold mb-2">Token cost unknown</h3>
        <p class="text-sm text-zinc-500">You see the total bill but not which tool calls or thinking steps consumed most tokens.</p>
      </div>
      <div class="glow-card p-6">
        <div class="text-3xl mb-3">🔗</div>
        <h3 class="font-semibold mb-2">Multi-agent chaos</h3>
        <p class="text-sm text-zinc-500">Agents pass messages, hand off tasks, and fail silently. No tool shows the full collaboration picture.</p>
      </div>
    </div>
  </section>

  <!-- Solution / Demo -->
  <section id="demo" class="max-w-5xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Every Step, Every Token, Every Decision
      </h2>
      <p class="text-zinc-400 max-w-xl mx-auto">
        The <strong class="text-zinc-200">agent debugging tool</strong> that gives you full visibility into your agent's behavior.
      </p>
    </div>

    <!-- Trace Timeline Mock -->
    <div class="glow-card p-6 mb-8">
      <div class="flex items-center gap-3 mb-6 pb-4 border-b border-zinc-800">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-red-500/50"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/50"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/50"></span>
        </div>
        <span class="text-xs text-zinc-600 font-mono">trace_7f3a2b — user_42 — 23 steps — 4.2s — $0.008</span>
        <span class="ml-auto text-xs text-red-400 font-medium">FAILED</span>
      </div>

      <div class="space-y-3">
        <div class="flex items-start gap-3 text-sm">
          <span class="text-indigo-400 font-mono mt-0.5">01</span>
          <div class="flex-1">
            <div class="text-zinc-300 font-medium mb-1">🤔 Think: Determine user intent</div>
            <div class="text-zinc-500 text-xs font-mono">"User wants to find pricing for enterprise tier..."</div>
          </div>
          <span class="text-zinc-600 text-xs font-mono">150 tok</span>
        </div>
        <div class="flex items-start gap-3 text-sm">
          <span class="text-green-400 font-mono mt-0.5">02</span>
          <div class="flex-1">
            <div class="text-zinc-300 font-medium mb-1">🔧 Tool: search_pricing_page</div>
            <div class="text-zinc-500 text-xs font-mono">search(query="enterprise pricing", limit=3)</div>
          </div>
          <span class="text-zinc-600 text-xs font-mono">320 tok</span>
        </div>
        <div class="flex items-start gap-3 text-sm">
          <span class="text-amber-400 font-mono mt-0.5">03</span>
          <div class="flex-1">
            <div class="text-zinc-300 font-medium mb-1">⚠️ Tool result: 404 — page not found</div>
            <div class="text-zinc-500 text-xs font-mono">Page was moved to /pricing/enterprise</div>
          </div>
          <span class="text-zinc-600 text-xs font-mono">85 tok</span>
        </div>
        <div class="flex items-start gap-3 text-sm">
          <span class="text-red-400 font-mono mt-0.5">04</span>
          <div class="flex-1">
            <div class="text-zinc-300 font-medium mb-1">❌ Output: "No pricing found" (incorrect)</div>
            <div class="text-zinc-500 text-xs font-mono">Should have retried with different query</div>
          </div>
          <span class="text-zinc-600 text-xs font-mono">210 tok</span>
        </div>
      </div>

      <div class="mt-4 pt-4 border-t border-zinc-800 flex items-center gap-4 text-xs text-zinc-500">
        <span>Failed at step 03 (tool result not handled)</span>
        <button class="text-indigo-400 hover:text-indigo-300 font-medium">▶ Replay this trace</button>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6 text-center">
      <div class="glow-card p-6">
        <div class="text-2xl font-bold gradient-text mb-1">Step-by-Step</div>
        <p class="text-sm text-zinc-500">See every thinking step, tool call, and decision in a timeline</p>
      </div>
      <div class="glow-card p-6">
        <div class="text-2xl font-bold gradient-text mb-1">Per-Step Cost</div>
        <p class="text-sm text-zinc-500">Token and cost breakdown for every step, not just the total</p>
      </div>
      <div class="glow-card p-6">
        <div class="text-2xl font-bold gradient-text mb-1">Failure Replay</div>
        <p class="text-sm text-zinc-500">Replay any failed trace to understand exactly what went wrong</p>
      </div>
    </div>
  </section>

  <!-- Multi-Agent Feature -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="bg-gradient-to-r from-indigo-900/20 via-purple-900/20 to-pink-900/20 rounded-2xl p-8 md:p-12 border border-zinc-800">
      <div class="max-w-2xl">
        <span class="text-xs text-indigo-400 font-semibold uppercase tracking-wider">独家功能 · Multi-Agent</span>
        <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-4">
          See How Your Agents <span class="gradient-text">Talk to Each Other</span>
        </h2>
        <p class="text-zinc-400 mb-6">
          Most monitoring tools only see a linear chain. Agent Debugger visualizes 
          multi-agent collaboration — who called whom, what messages passed between them, 
          and where the handoff failed.
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-xs">Agent topology map</span>
          <span class="px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-300 text-xs">Cross-agent traces</span>
          <span class="px-3 py-1 rounded-full bg-pink-500/10 border border-pink-500/20 text-pink-300 text-xs">Collaboration errors</span>
          <span class="px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-xs">Message context viewer</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Frameworks -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">Works With Any Framework</h2>
      <p class="text-zinc-400 max-w-xl mx-auto">
        One SDK. Drop-in instrumentation for every major agent framework.
      </p>
    </div>
    <div class="grid md:grid-cols-4 gap-4">
      <div class="glow-card p-5 text-center">
        <div class="text-lg font-mono font-bold mb-1">AutoGen</div>
        <div class="text-xs text-zinc-500">pip install ad-autogen</div>
      </div>
      <div class="glow-card p-5 text-center">
        <div class="text-lg font-mono font-bold mb-1">CrewAI</div>
        <div class="text-xs text-zinc-500">pip install ad-crewai</div>
      </div>
      <div class="glow-card p-5 text-center">
        <div class="text-lg font-mono font-bold mb-1">LangGraph</div>
        <div class="text-xs text-zinc-500">npm i @ad/langgraph</div>
      </div>
      <div class="glow-card p-5 text-center">
        <div class="text-lg font-mono font-bold mb-1">Custom</div>
        <div class="text-xs text-zinc-500">from ad import trace</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="cta" class="max-w-3xl mx-auto px-4 py-24 text-center">
    <div class="glow-card p-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        Start Debugging Your Agents
      </h2>
      <p class="text-zinc-400 mb-8 max-w-md mx-auto">
        Free during beta. No credit card. Full access to traces, replay, and multi-agent visualization.
      </p>
      <a href="/app/register" class="btn-primary text-lg px-8 py-4 inline-block">
        Create Free Account →
      </a>
      <p class="text-xs text-zinc-600 mt-4">Join 200+ developers debugging their agents</p>
    </div>
  </section>
</Layout>
